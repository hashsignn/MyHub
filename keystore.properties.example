# Copy this file to `keystore.properties` (same folder, repo root) and fill in real values.
# `keystore.properties` is gitignored — never commit it or the .jks file it points to.
#
# Generate the keystore first (see RELEASE.md), then point storeFile at it. A relative path is
# resolved from the repo root; an absolute path also works.

storeFile=contentreg-release.jks
storePassword=CHANGE_ME
keyAlias=contentreg
keyPassword=CHANGE_ME
