<?xml version="1.0" encoding="utf-8"?>
<!-- Settings: reel surfaces to block, disguise, uninstall protection, custom shortcut, privacy. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_reels_heading"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="4dp"
            android:text="@string/settings_reels_subtitle"
            android:textSize="13sp" />

        <CheckBox
            android:id="@+id/reelInstagram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reel_app_instagram" />

        <CheckBox
            android:id="@+id/reelYoutube"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reel_app_youtube" />

        <CheckBox
            android:id="@+id/reelFacebook"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reel_app_facebook" />

        <CheckBox
            android:id="@+id/reelSnapchat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reel_app_snapchat" />

        <CheckBox
            android:id="@+id/reelTiktok"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/reel_app_tiktok" />

        <!-- Digital Detox — status + signature management (locked while a detox runs). -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_detox_heading"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/detoxSettingsStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            tools:text="Active — 42m left" />

        <TextView
            android:id="@+id/detoxSignatureStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            tools:text="A signature is set." />

        <TextView
            android:id="@+id/detoxSignatureLockNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/detox_sig_locked"
            android:textColor="@color/status_warn"
            android:textSize="13sp"
            android:visibility="gone" />

        <EditText
            android:id="@+id/detoxCurrentSignatureEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/detox_sig_current_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLines="1" />

        <EditText
            android:id="@+id/detoxNewSignatureEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/detox_sig_new_hint"
            android:importantForAutofill="no"
            android:inputType="text"
            android:maxLines="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/detoxSaveSignatureButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/detox_sig_save" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_disguise_heading"
            android:textSize="16sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/disguiseDefaultButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/disguise_default" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/disguiseCalcButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/disguise_calculator" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/disguiseNotesButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/disguise_notes" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_privacy_heading"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/viewDisclosureButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/settings_view_disclosure" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_admin_heading"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/adminStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="13sp"
            tools:text="Off — the app can be uninstalled normally." />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/adminToggleButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/admin_turn_on" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/settings_shortcut_heading"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/settings_shortcut_subtitle"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/shortcutLabelEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:hint="@string/shortcut_label_hint"
            android:importantForAutofill="no"
            android:inputType="textCapWords"
            android:maxLines="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/addShortcutButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/shortcut_add_button" />

    </LinearLayout>

</ScrollView>
