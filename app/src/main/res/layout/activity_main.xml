<?xml version="1.0" encoding="utf-8"?>
<!-- M0.0–M1.3 — dev dashboard: permissions, live sensing readouts, budget, and test controls.
     A ScrollView keeps it usable as more rows are added; a polished dashboard arrives in M4.2. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textSize="14sp"
            tools:text="Phase 0 — build pipeline OK" />

        <!-- Permissions -->
        <TextView
            android:id="@+id/accessibilityStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Accessibility: OFF — tap below to enable" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/enableAccessibilityButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/m10_enable_accessibility" />

        <TextView
            android:id="@+id/overlayStateText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textSize="16sp"
            android:textStyle="bold"
            tools:text="Overlay permission: OFF — needed to block" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/grantOverlayButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/m13_grant_overlay" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openSettingsButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/m14_open_settings" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openOnboardingButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/m41_open_onboarding" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/openDashboardButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/m42_open_dashboard" />

        <!-- Live sensing readouts -->
        <TextView
            android:id="@+id/foregroundLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/m10_foreground_label"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/foregroundPackageText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textIsSelectable="true"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="com.instagram.android" />

        <TextView
            android:id="@+id/scrollLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/m11_scroll_label"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/scrollCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="42 (last: com.instagram.android)" />

        <TextView
            android:id="@+id/budgetLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/m12_budget_label"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/budgetValueText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="0:12 used / 5:00 — 4:48 left" />

        <!-- Test controls (M1.3) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/testExhaustButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/m13_test_exhaust" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/testResetButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/m13_test_reset" />

        <!-- URL filter (M2.1) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/m21_section"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/vpnToggleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/m21_start_vpn" />

        <EditText
            android:id="@+id/blockDomainEdit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:autofillHints="domain"
            android:hint="@string/m21_block_domain_hint"
            android:inputType="textUri"
            android:maxLines="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/blockDomainButton"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/m21_block_domain" />

        <TextView
            android:id="@+id/registryCountText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            tools:text="Blocked entries in registry: 3" />

    </LinearLayout>

</ScrollView>
