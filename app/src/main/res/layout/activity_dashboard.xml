<?xml version="1.0" encoding="utf-8"?>
<!-- M4.2 — simple stats dashboard. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/dashboard_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/streakText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:textSize="18sp"
            tools:text="Daily streak: 3 days" />

        <TextView
            android:id="@+id/blocksText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="18sp"
            tools:text="Feed blocks triggered: 12" />

        <TextView
            android:id="@+id/usageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="18sp"
            tools:text="Feed time used this hour: 4:48" />

        <TextView
            android:id="@+id/registryText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textSize="18sp"
            tools:text="Sites in block registry: 102" />

    </LinearLayout>

</ScrollView>
