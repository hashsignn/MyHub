<?xml version="1.0" encoding="utf-8"?>
<!-- Digital Detox setup: choose duration, allowed apps, and confirm with the signature. -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/detox_setup_intro"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="14sp" />

        <!-- Duration -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.ContentReg.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detox_duration_heading"
                    android:textAppearance="@style/TextAppearance.ContentReg.Section" />

                <RadioGroup
                    android:id="@+id/durationGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/dur30m"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/detox_dur_30m" />

                    <RadioButton
                        android:id="@+id/dur1h"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/detox_dur_1h" />

                    <RadioButton
                        android:id="@+id/dur2h"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/detox_dur_2h" />

                    <RadioButton
                        android:id="@+id/dur4h"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/detox_dur_4h" />

                    <RadioButton
                        android:id="@+id/dur8h"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/detox_dur_8h" />
                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Allowed apps -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.ContentReg.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detox_allowed_heading"
                    android:textAppearance="@style/TextAppearance.ContentReg.Section" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/detox_allowed_subtitle"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/appsLoadingText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/detox_loading_apps"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="14sp" />

                <!-- Checkboxes are added here at runtime. -->
                <LinearLayout
                    android:id="@+id/appListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Signature confirm -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.ContentReg.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/detox_signature_heading"
                    android:textAppearance="@style/TextAppearance.ContentReg.Section" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/detox_signature_note"
                    android:textColor="?android:attr/textColorSecondary"
                    android:textSize="13sp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/signatureLayout"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:hint="@string/detox_signature_confirm_hint">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/signatureEdit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startDetoxButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/detox_red"
            android:paddingVertical="14dp"
            android:text="@string/detox_start_button"
            android:textColor="@color/on_detox"
            android:textStyle="bold"
            app:cornerRadius="14dp" />

    </LinearLayout>

</ScrollView>
