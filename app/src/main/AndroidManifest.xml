<?xml version="1.0" encoding="utf-8"?>
<!--
  M0.0 — base manifest. Declares the application and the launcher activity.
  Future milestones add to this file:
    M1.0  AccessibilityService (+ BIND_ACCESSIBILITY_SERVICE)
    M1.3  SYSTEM_ALERT_WINDOW overlay permission
    M2.1  VpnService (+ BIND_VPN_SERVICE)
    M4.0  <activity-alias> launcher icons
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- M2.1 — required for the upstream DNS forwarding socket in FilterVpnService. -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Bug #6 — VPN foreground service (specialUse type, API 34+). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- M1.3 — draw the block screen over other apps. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- M1.4 — see launchable apps so the settings picker can list them (Android 11+ visibility). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".App"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.ContentRegApp">

        <!-- M4.0 — MainActivity no longer carries the launcher filter itself; the launcher
             icon/label is provided by exactly one enabled <activity-alias> below, switchable at
             runtime by IconAliasController. -->
        <activity
            android:name=".MainActivity"
            android:exported="true" />

        <!-- Default disguise (enabled). -->
        <activity-alias
            android:name=".Default"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Calculator disguise (disabled by default). -->
        <activity-alias
            android:name=".AliasCalculator"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_alias_calc"
            android:label="@string/alias_calculator_label"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- Notes disguise (disabled by default). -->
        <activity-alias
            android:name=".AliasNotes"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_alias_notes"
            android:label="@string/alias_notes_label"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- M1.4 — budget length + target-app picker. -->
        <activity
            android:name=".feature1_doomscroll.ui.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title"
            android:parentActivityName=".MainActivity" />

        <!-- Task 1 — prominent disclosure & consent, shown before onboarding / any sensitive access. -->
        <activity
            android:name=".feature4_retention.consent.ConsentActivity"
            android:exported="false"
            android:label="@string/consent_heading"
            android:parentActivityName=".MainActivity" />

        <!-- M4.1 — permission onboarding. -->
        <activity
            android:name=".feature4_retention.onboarding.OnboardingActivity"
            android:exported="false"
            android:label="@string/onb_heading"
            android:parentActivityName=".MainActivity" />

        <!-- M4.2 — stats dashboard. -->
        <activity
            android:name=".feature4_retention.stats.DashboardActivity"
            android:exported="false"
            android:label="@string/dashboard_title"
            android:parentActivityName=".MainActivity" />

        <!-- M2.1 — local DNS-filtering VPN (BIND_VPN_SERVICE-guarded; only the system binds it).
             Bug #6: foregroundServiceType=specialUse keeps the service alive when backgrounded. -->
        <service
            android:name=".feature2_url.FilterVpnService"
            android:exported="false"
            android:foregroundServiceType="specialUse"
            android:permission="android.permission.BIND_VPN_SERVICE">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="VPN-based domain filter — no traffic leaves the device" />
        </service>

        <!-- M1.0 — the single AccessibilityService (foreground sensing).
             Guarded by BIND_ACCESSIBILITY_SERVICE so only the system can bind it. -->
        <service
            android:name=".core.sensing.ForegroundService"
            android:exported="true"
            android:label="@string/accessibility_service_label"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

    </application>

</manifest>
